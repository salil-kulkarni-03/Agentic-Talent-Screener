# ── Groq API Settings (Required for Backend) ──────────────────────────────────
# Create a free API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── GitHub Token Settings (Optional - Boosts Rate Limits) ────────────────────
# Create a personal token (read-only) at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_token_here

# ── Backend Deployment CORS Setup ─────────────────────────────────────────────
# In production on Render, set this to your frontend Vercel URL
FRONTEND_URL=http://localhost:5173

# ── Frontend Deployment API Settings (Set on Vercel) ─────────────────────────
# In production on Vercel, set this to your backend Render URL
VITE_API_URL=http://localhost:8000
